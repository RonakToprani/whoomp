{
  "expo": {
    "name": "whoomp",
    "slug": "whoomp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ronakto.whoomp",
      "infoPlist": {
        "UIBackgroundModes": ["bluetooth-central"],
        "NSBluetoothAlwaysUsageDescription": "whoomp uses Bluetooth to connect to your WHOOP strap and read biometric data.",
        "NSBluetoothPeripheralUsageDescription": "whoomp uses Bluetooth to connect to your WHOOP strap and read biometric data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "Allow whoomp to connect to your WHOOP strap over Bluetooth."
        }
      ],
      "expo-dev-client"
    ]
  }
}
